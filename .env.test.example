# Copy this file to .env.test and fill in your values.
# .env.test is gitignored — never commit real credentials.

TEST_EMAIL=your-test-account@example.com
TEST_PASSWORD=your-test-password

# TEST_FRESH_EMAIL is auto-generated in the test using a +alias trick.
# Leave blank here — the test generates: testuser+<timestamp>@gmail.com
TEST_FRESH_EMAIL=
